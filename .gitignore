# =================================================================
# GENERAL - OS, IDE, and Environment Files
# =================================================================

# Operating System files
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE settings
.vscode/
.idea/

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =================================================================
# FRONTEND - Next.js
# =================================================================

# Dependencies (this one rule covers all node_modules folders)
node_modules/

# Other dependency management files
.pnp
.pnp.js

# Next.js build output (this one rule covers .next folders everywhere)
.next/
out/

# =================================================================
# BACKEND - Python / Flask
# =================================================================

# Python virtual environment
.venv/
venv/
env/

# Python cache files
__pycache__/
*.pyc

# Flask instance folder
instance/

# User-uploaded content
webapp/uploads/

# =================================================================
# BUILD & TEST - Production and Coverage Artifacts
# =================================================================
build/
coverage/